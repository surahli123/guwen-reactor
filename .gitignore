# --- Secrets & credentials (NEVER commit) -----------------------------------
# This project's whole premise is that no API key sits in the judged path.
# Block every credential shape we might touch during the build, especially the
# Google ADC service-account JSON used for Gemini/ADK auth.
.env
.env.*
*.key
*.pem
secrets.*
credentials.json
service-account*.json
application_default_credentials.json
*.credentials

# --- Python -----------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Run / build output (created during the build, never source) ------------
# The spec confines all generated artifacts to runs/<id>/; keep them out of git.
# EXCEPT the two committed demo fixtures (demo_clean / demo_drift): they are the offline
# test inputs the eval core TDDs against and the canvas renders (Task 3.1, review #1).
runs/*
!runs/demo_clean/
!runs/demo_drift/
!runs/g02_clean/
!runs/g03_clean/

# Map-geometry build inputs/outputs (regenerable via tools/build_geo.py)
tools/*.geojson
tools/mapgeo.js
# ...but generated run OUTPUTS (trace/manifest) are not fixtures — re-ignore them.
runs/**/trace.jsonl
runs/**/manifest.yaml
*.log
dist/
build/

# --- Agent tooling state (auto-generated in cwd, never project content) -----
# oh-my-claudecode writes session/HUD/orchestration state into .omc/ wherever
# it runs; keep it out of the repo.
.omc/
.claude/

# --- Personal session artifacts (mirrors the pre-commit hook policy) --------
# Dated handover notes are session-continuity scaffolding, not deliverables;
# the canonical copies live in ~/notes/. Keep them local-only.
handover-20*.md

# --- OS / editor ------------------------------------------------------------
.DS_Store
.idea/
.vscode/
*.swp
.gstack/
designs/**/prototypes/shots/
